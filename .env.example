# Copy this file to .env.local and fill in your values
# Get Supabase values from: Project Settings > API

# ── SUPABASE ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — NEVER prefix with NEXT_PUBLIC_, never expose to browser
# Used only in server-side cron job. Get from: Project Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── RESEND (email) ─────────────────────────────────────────
RESEND_API_KEY=re_your-key-here

# ── SITE ───────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://rotmarket.gg

# ── ADMIN ──────────────────────────────────────────────────
ADMIN_EMAIL=you@gmail.com

# ── CRON ───────────────────────────────────────────────────
# Generate: openssl rand -hex 32
CRON_SECRET=your-random-secret-here
